generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entreprise {
  id                   String                @id @default(uuid())
  nom                  String
  logo                 String?
  email                String                @unique
  telephone            String?
  adresse              String?
  devise               String                @default("MAD")
  plan                 PlanType              @default(STARTER)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  couleurPrimaire      String?               @default("#2563eb")
  templateDocument     String                @default("classic")
  formatDate           String?               @default("DD/MM/YYYY")
  ice                  String?
  pays                 String?               @default("Maroc")
  planExpiration       DateTime?
  planDebut            DateTime?
  rc                   String?
  ville                String?
  website              String?
  titulaireCompte      String?
  banque               String?
  rib                  String?
  iban                 String?
  swift                String?
  typeCompte           String?               @default("pme")
  activite             String?
  tauxEUR               Float?
  tauxUSD               Float?
  regimeTVA             String                @default("ENCAISSEMENTS")
  prefixeFacture        String                @default("FAC")
  prefixeDevis          String                @default("DEV")
  prefixeBL             String                @default("BL")
  prochainNumeroFacture Int                   @default(1)
  prochainNumeroDevis   Int                   @default(1)
  prochainNumeroBL      Int                   @default(1)
  storageUsedBytes      Int                   @default(0)
  dgiMode               Boolean               @default(false)
  clients               Client[]
  produitsServices     ProduitService[]
  declarationsPaiement DeclarationPaiement[]
  devis                Devis[]
  factures             Facture[]
  notifications        Notification[]
  paiements            Paiement[]
  utilisateurs         Utilisateur[]
  bonsLivraison        BonLivraison[]
  depenses             Depense[]

  @@map("entreprises")
}

model CompteGlobal {
  id             String        @id @default(uuid())
  email          String        @unique
  motDePasseHash String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  utilisateurs   Utilisateur[]

  @@map("comptes_globaux")
}

model Utilisateur {
  id                        String                   @id @default(uuid())
  entrepriseId              String
  nom                       String
  email                     String
  motDePasseHash            String?
  role                      RoleType                 @default(COMMERCIAL)
  actif                     Boolean                  @default(true)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  langue                    String?                  @default("fr")
  telephone                 String?
  theme                     String?                  @default("system")
  dernierAcces                  DateTime?
  invitationToken               String?                  @unique
  invitationTokenExpiration     DateTime?
  prenom                        String?
  emailConfirme                 Boolean                  @default(false)
  emailConfirmationToken        String?                  @unique
  emailConfirmationExpiration   DateTime?
  resetPasswordToken            String?                  @unique
  resetPasswordExpiration       DateTime?
  superAdmin                    Boolean                  @default(false)
  permissionsRetirees           String[]                 @default([])
  compteGlobalId            String?
  compteGlobal              CompteGlobal?            @relation(fields: [compteGlobalId], references: [id], onDelete: SetNull)
  preferencesNotification   PreferencesNotification?
  entreprise                Entreprise               @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@unique([entrepriseId, email])
  @@map("utilisateurs")
}

model PreferencesNotification {
  id                     String      @id @default(uuid())
  utilisateurId          String      @unique
  emailNotifications     Boolean     @default(false)
  notificationsDevis     Boolean     @default(false)
  notificationsFactures  Boolean     @default(false)
  notificationsPaiements Boolean     @default(false)
  notificationsSysteme   Boolean     @default(false)
  inAppDevis             Boolean     @default(true)
  inAppFactures          Boolean     @default(true)
  inAppPaiements         Boolean     @default(true)
  inAppSysteme           Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  utilisateur            Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@map("preferences_notifications")
}

model Client {
  id            String      @id @default(uuid())
  entrepriseId  String
  nom           String
  email         String?
  telephone     String?
  nomEntreprise String?
  ice           String?
  ifFiscal      String?
  rasActif      Boolean     @default(false)
  rasTaux       Decimal     @default(30) @db.Decimal(5, 2)
  notes         String?
  actif         Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  typeClient    TypeClient  @default(PARTICULIER)
  portalToken   String      @unique @default(uuid())
  entreprise      Entreprise       @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  devis           Devis[]
  factures        Facture[]
  bonsLivraison   BonLivraison[]

  @@index([entrepriseId])
  @@map("clients")
}

model Devis {
  id                       String           @id @default(uuid())
  entrepriseId             String
  clientId                 String
  reference                String
  statut                   StatutDevis      @default(BROUILLON)
  totalHT                  Decimal          @default(0) @db.Decimal(12, 2)
  taxe                     Decimal          @default(20) @db.Decimal(5, 2)
  totalTTC                 Decimal          @default(0) @db.Decimal(12, 2)
  dateExpiration           DateTime?
  dateAcceptation          DateTime?
  notes                    String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  remise                   Decimal          @default(0) @db.Decimal(12, 2)
  devise                   String           @default("MAD")
  dateRefus                DateTime?
  dateEnvoi                DateTime?
  dateConsultation         DateTime?
  dateDerniereConsultation DateTime?
  nombreConsultations      Int              @default(0)
  client                   Client           @relation(fields: [clientId], references: [id])
  entreprise               Entreprise       @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  lignes                   DevisLigne[]
  factures                 Facture[]
  lienPublic               LienPublicDevis?
  bonsLivraison            BonLivraison[]

  @@index([entrepriseId])
  @@index([clientId])
  @@map("devis")
}

model DevisLigne {
  id           String  @id @default(uuid())
  devisId      String
  description  String
  quantite     Decimal @default(1) @db.Decimal(10, 3)
  prixUnitaire Decimal @default(0) @db.Decimal(12, 2)
  total        Decimal @default(0) @db.Decimal(12, 2)
  ordre        Int     @default(0)
  devis        Devis   @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@map("devis_lignes")
}

model LienPublicDevis {
  id         String   @id @default(uuid())
  devisId    String   @unique
  token      String   @unique @default(uuid())
  expiration DateTime
  utilise    Boolean  @default(false)
  createdAt  DateTime @default(now())
  devis      Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@map("liens_publics_devis")
}

model Facture {
  id                       String                @id @default(uuid())
  entrepriseId             String
  clientId                 String
  devisId                  String?
  numeroFacture            String
  statut                   StatutFacture         @default(BROUILLON)
  totalHT                  Decimal               @default(0) @db.Decimal(12, 2)
  taxe                     Decimal               @default(20) @db.Decimal(5, 2)
  totalTTC                 Decimal               @default(0) @db.Decimal(12, 2)
  remise                   Decimal               @default(0) @db.Decimal(12, 2)
  rasActif                 Boolean               @default(false)
  rasTaux                  Decimal               @default(30) @db.Decimal(5, 2)
  rasMontant               Decimal               @default(0) @db.Decimal(12, 2)
  devise                   String                @default("MAD")
  montantPaye              Decimal               @default(0) @db.Decimal(12, 2)
  dateEcheance             DateTime?
  notes                    String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  publicToken              String                @unique @default(uuid())
  dateEnvoi                DateTime?
  dateConsultation         DateTime?
  dateDerniereConsultation DateTime?
  nombreConsultations      Int                   @default(0)
  lastReminderSentAt       DateTime?
  dgiMode                  Boolean               @default(false)
  dgiStatut                DGIStatut?
  dgiClearanceId           String?
  dgiSoumisAt              DateTime?
  dgiValideAt              DateTime?
  dgiRaisonRejet           String?
  xmlStorageKey            String?
  pdfStorageKey            String?
  documentHash             String?
  declarationsPaiement     DeclarationPaiement[]
  lignes                   FactureLigne[]
  client                   Client                @relation(fields: [clientId], references: [id])
  devis                    Devis?                @relation(fields: [devisId], references: [id])
  entreprise               Entreprise            @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  paiements                Paiement[]
  bonsLivraison            BonLivraison[]

  @@unique([entrepriseId, numeroFacture])
  @@index([entrepriseId])
  @@index([clientId])
  @@map("factures")
}

model FactureLigne {
  id           String  @id @default(uuid())
  factureId    String
  description  String
  quantite     Decimal @default(1) @db.Decimal(10, 3)
  prixUnitaire Decimal @default(0) @db.Decimal(12, 2)
  total        Decimal @default(0) @db.Decimal(12, 2)
  ordre        Int     @default(0)
  facture      Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@map("facture_lignes")
}

model Paiement {
  id           String          @id @default(uuid())
  entrepriseId String
  factureId    String
  montant      Decimal         @db.Decimal(12, 2)
  methode      MethodePaiement @default(VIREMENT)
  reference    String?
  datePaiement DateTime        @default(now())
  notes        String?
  createdAt    DateTime        @default(now())
  entreprise   Entreprise      @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  facture      Facture         @relation(fields: [factureId], references: [id])

  @@index([entrepriseId])
  @@index([factureId])
  @@map("paiements")
}

model Notification {
  id           String           @id @default(uuid())
  entrepriseId String
  type         TypeNotification
  message      String
  lu           Boolean          @default(false)
  lien         String?
  createdAt    DateTime         @default(now())
  entreprise   Entreprise       @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@index([entrepriseId])
  @@index([lu])
  @@map("notifications")
}

model DeclarationPaiement {
  id           String            @id @default(uuid())
  entrepriseId String
  factureId    String
  montant      Decimal           @db.Decimal(12, 2)
  methode      MethodePaiement   @default(VIREMENT)
  reference    String?
  message      String?
  datePaiement DateTime          @default(now())
  statut       StatutDeclaration @default(PENDING)
  raisonRejet  String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  entreprise   Entreprise        @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  facture      Facture           @relation(fields: [factureId], references: [id])

  @@index([entrepriseId])
  @@index([factureId])
  @@map("declarations_paiement")
}

enum PlanType {
  STARTER
  PRO
  BUSINESS
}

enum RoleType {
  ADMIN
  MANAGER
  COMMERCIAL
  COMPTABLE
  PROPRIETAIRE
  DAF
  COMPTABLE_EXTERNE
  RESPONSABLE_RECOUVREMENT
  CAISSIER
  COMMERCIAL_PROPRE
  ASSISTANT
  ASSOCIE
}

enum StatutDevis {
  BROUILLON
  ENVOYE
  VU
  ACCEPTE
  REFUSE
}

enum StatutFacture {
  BROUILLON
  CLEARANCE_EN_COURS
  ENVOYEE
  REJETEE_DGI
  PAYEE
  PARTIELLE
  EN_RETARD
  VUE
  ANNULEE
}

enum DGIStatut {
  EN_ATTENTE
  VALIDEE
  REJETEE
}

enum MethodePaiement {
  CASH
  VIREMENT
  CARTE
  CHEQUE
  MOBILE
  AUTRE
}

enum TypeNotification {
  DEVIS_ENVOYE
  DEVIS_ACCEPTE
  DEVIS_REFUSE
  DEVIS_VU
  FACTURE_CREEE
  FACTURE_PAYEE
  FACTURE_PARTIELLE
  RAPPEL_ECHEANCE
  PAIEMENT_RECU
  FACTURE_ENVOYEE
  FACTURE_VUE
  DECLARATION_RECUE
}

enum StatutDeclaration {
  PENDING
  APPROVED
  REJECTED
}

enum TypeClient {
  PARTICULIER
  ENTREPRISE
  FREELANCE
}

enum TypeItem {
  PRODUIT
  SERVICE
}

enum StatutBonLivraison {
  BROUILLON
  ENVOYE
  LIVRE
}

model ProduitService {
  id           String     @id @default(uuid())
  entrepriseId String
  nom          String
  description  String?
  type         TypeItem   @default(SERVICE)
  prixUnitaire Decimal    @default(0) @db.Decimal(12, 2)
  unite        String?    @default("forfait")
  actif        Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  entreprise   Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@index([entrepriseId])
  @@map("produits_services")
}

model ActivityLog {
  id           String   @id @default(uuid())
  entrepriseId String
  userId       String
  userNom      String
  action       String
  entityType   String
  entityId     String?
  entityRef    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([entrepriseId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model BonLivraison {
  id             String              @id @default(uuid())
  reference      String
  statut         StatutBonLivraison  @default(BROUILLON)
  entrepriseId   String
  clientId       String
  devisId        String?
  notes          String?
  dateLivraison  DateTime?
  publicToken    String              @unique @default(uuid())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  factureId      String?
  client         Client              @relation(fields: [clientId], references: [id])
  devis          Devis?              @relation(fields: [devisId], references: [id])
  facture        Facture?            @relation(fields: [factureId], references: [id], onDelete: SetNull)
  entreprise     Entreprise          @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  lignes         BonLivraisonLigne[]

  @@unique([entrepriseId, reference])
  @@index([entrepriseId])
  @@index([clientId])
  @@map("bons_livraison")
}

model BonLivraisonLigne {
  id             String       @id @default(uuid())
  bonLivraisonId String
  description    String
  quantite       Decimal      @default(1) @db.Decimal(10, 3)
  prixUnitaire   Decimal      @default(0) @db.Decimal(12, 2)
  unite          String?
  ordre          Int          @default(0)
  bonLivraison   BonLivraison @relation(fields: [bonLivraisonId], references: [id], onDelete: Cascade)

  @@map("bon_livraison_lignes")
}

enum CategorieDepense {
  LOYER
  EQUIPEMENT
  TRANSPORT
  ABONNEMENTS
  MATIERES_PREMIERES
  SALAIRES
  MARKETING
  FOURNITURES
  SOUS_TRAITANCE
  AUTRE
}

model Depense {
  id                      String           @id @default(uuid())
  entrepriseId            String
  userId                  String
  montant                 Decimal          @db.Decimal(12, 2)
  devise                  String           @default("MAD")
  tauxTva                 Decimal          @default(0) @db.Decimal(5, 2)
  montantTva              Decimal          @default(0) @db.Decimal(12, 2)
  categorie               CategorieDepense
  categoriePersonnalisee  String?
  fournisseur             String?
  description             String?
  date                    DateTime
  receiptKey              String?
  receiptUrl              String?
  receiptSizeBytes        Int?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  entreprise              Entreprise       @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@index([entrepriseId])
  @@map("depenses")
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  company   String?
  subject   String
  message   String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email])
  @@map("contact_submissions")
}
