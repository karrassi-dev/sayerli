generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENTREPRISE (Company) - Multi-tenant root
// ============================================
model Entreprise {
  id             String   @id @default(uuid())
  nom            String
  logo           String?
  couleurPrimaire String? @default("#2563eb")
  email          String   @unique
  telephone      String?
  adresse        String?
  ville          String?
  pays           String?  @default("Maroc")
  website        String?
  ice            String?
  rc             String?
  devise         String   @default("MAD")
  formatDate     String?  @default("DD/MM/YYYY")
  plan           PlanType @default(STARTER)
  planExpiration DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  utilisateurs  Utilisateur[]
  clients       Client[]
  devis         Devis[]
  factures      Facture[]
  paiements     Paiement[]
  notifications Notification[]

  @@map("entreprises")
}

enum PlanType {
  STARTER
  PRO
  BUSINESS
}

// ============================================
// UTILISATEUR (User)
// ============================================
model Utilisateur {
  id                        String    @id @default(uuid())
  entrepriseId              String
  prenom                    String?
  nom                       String
  email                     String
  motDePasseHash            String?
  role                      RoleType  @default(COMMERCIAL)
  telephone                 String?
  langue                    String?   @default("fr")
  theme                     String?   @default("system")
  actif                     Boolean   @default(true)
  invitationToken           String?   @unique
  invitationTokenExpiration DateTime?
  dernierAcces              DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  entreprise              Entreprise               @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  preferencesNotification PreferencesNotification?

  @@unique([entrepriseId, email])
  @@map("utilisateurs")
}

// ============================================
// PREFERENCES NOTIFICATION
// ============================================
model PreferencesNotification {
  id                      String   @id @default(uuid())
  utilisateurId           String   @unique
  emailNotifications      Boolean  @default(true)
  notificationsDevis      Boolean  @default(true)
  notificationsFactures   Boolean  @default(true)
  notificationsPaiements  Boolean  @default(true)
  notificationsSysteme    Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  utilisateur Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@map("preferences_notifications")
}

enum RoleType {
  ADMIN
  MANAGER
  COMMERCIAL
  COMPTABLE
}

// ============================================
// CLIENT (CRM)
// ============================================
model Client {
  id            String   @id @default(uuid())
  entrepriseId  String
  nom           String
  email         String?
  telephone     String?
  nomEntreprise String?
  notes         String?
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  devis      Devis[]
  factures   Facture[]

  @@index([entrepriseId])
  @@map("clients")
}

// ============================================
// DEVIS (Quote)
// ============================================
model Devis {
  id              String      @id @default(uuid())
  entrepriseId    String
  clientId        String
  reference       String
  statut          StatutDevis @default(BROUILLON)
  totalHT         Decimal     @default(0) @db.Decimal(12, 2)
  remise          Decimal     @default(0) @db.Decimal(12, 2)
  taxe            Decimal     @default(20) @db.Decimal(5, 2)
  totalTTC        Decimal     @default(0) @db.Decimal(12, 2)
  dateExpiration  DateTime?
  dateAcceptation DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  entreprise    Entreprise      @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  client        Client          @relation(fields: [clientId], references: [id])
  lignes        DevisLigne[]
  lienPublic    LienPublicDevis?
  factures      Facture[]

  @@index([entrepriseId])
  @@index([clientId])
  @@map("devis")
}

enum StatutDevis {
  BROUILLON
  ENVOYE
  VU
  ACCEPTE
  REFUSE
}

// ============================================
// DEVIS LIGNES (Quote Items)
// ============================================
model DevisLigne {
  id           String  @id @default(uuid())
  devisId      String
  description  String
  quantite     Decimal @default(1) @db.Decimal(10, 3)
  prixUnitaire Decimal @default(0) @db.Decimal(12, 2)
  total        Decimal @default(0) @db.Decimal(12, 2)
  ordre        Int     @default(0)

  devis Devis @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@map("devis_lignes")
}

// ============================================
// LIEN PUBLIC DEVIS (Public Quote Link)
// ============================================
model LienPublicDevis {
  id         String   @id @default(uuid())
  devisId    String   @unique
  token      String   @unique @default(uuid())
  expiration DateTime
  utilise    Boolean  @default(false)
  createdAt  DateTime @default(now())

  devis Devis @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@map("liens_publics_devis")
}

// ============================================
// FACTURE (Invoice)
// ============================================
model Facture {
  id             String        @id @default(uuid())
  entrepriseId   String
  clientId       String
  devisId        String?
  numeroFacture  String
  statut         StatutFacture @default(BROUILLON)
  totalHT        Decimal       @default(0) @db.Decimal(12, 2)
  taxe           Decimal       @default(20) @db.Decimal(5, 2)
  totalTTC       Decimal       @default(0) @db.Decimal(12, 2)
  montantPaye    Decimal       @default(0) @db.Decimal(12, 2)
  dateEcheance   DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  entreprise Entreprise    @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  client     Client        @relation(fields: [clientId], references: [id])
  devis      Devis?        @relation(fields: [devisId], references: [id])
  lignes     FactureLigne[]
  paiements  Paiement[]

  @@unique([entrepriseId, numeroFacture])
  @@index([entrepriseId])
  @@index([clientId])
  @@map("factures")
}

enum StatutFacture {
  BROUILLON
  ENVOYEE
  PAYEE
  PARTIELLE
  EN_RETARD
}

// ============================================
// FACTURE LIGNES (Invoice Items)
// ============================================
model FactureLigne {
  id           String  @id @default(uuid())
  factureId    String
  description  String
  quantite     Decimal @default(1) @db.Decimal(10, 3)
  prixUnitaire Decimal @default(0) @db.Decimal(12, 2)
  total        Decimal @default(0) @db.Decimal(12, 2)
  ordre        Int     @default(0)

  facture Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@map("facture_lignes")
}

// ============================================
// PAIEMENT (Payment)
// ============================================
model Paiement {
  id           String          @id @default(uuid())
  entrepriseId String
  factureId    String
  montant      Decimal         @db.Decimal(12, 2)
  methode      MethodePaiement @default(VIREMENT)
  reference    String?
  datePaiement DateTime        @default(now())
  notes        String?
  createdAt    DateTime        @default(now())

  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  facture    Facture    @relation(fields: [factureId], references: [id])

  @@index([entrepriseId])
  @@index([factureId])
  @@map("paiements")
}

enum MethodePaiement {
  CASH
  VIREMENT
  CARTE
  CHEQUE
  MOBILE
}

// ============================================
// NOTIFICATION
// ============================================
model Notification {
  id           String            @id @default(uuid())
  entrepriseId String
  type         TypeNotification
  message      String
  lu           Boolean           @default(false)
  lien         String?
  createdAt    DateTime          @default(now())

  entreprise Entreprise @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)

  @@index([entrepriseId])
  @@index([lu])
  @@map("notifications")
}

enum TypeNotification {
  DEVIS_ENVOYE
  DEVIS_ACCEPTE
  DEVIS_REFUSE
  DEVIS_VU
  FACTURE_CREEE
  FACTURE_PAYEE
  FACTURE_PARTIELLE
  RAPPEL_ECHEANCE
  PAIEMENT_RECU
}
